{
	"name": "seo-simple-pack",
	"version": "1.0.0",
	"description": "WordPress プラグイン、[SEO SIMPLE PACK](https://wordpress.org/plugins/seo-simple-pack/)。",
	"main": "index.js",
	"scripts": {
		"build": "pnpm build:css && pnpm build:js",
		"build:css": "node sass-builder.js",
		"build:js": "webpack",
		"set:composer": "composer i && composer set-wpcs",
		"update": "bash ./bin/zip.sh",
		"rm:ds_store": "find . -name '.DS_Store' -type f -ls -delete"
	},
	"repository": {
		"type": "git",
		"url": "git+https://ddryo@github.com/ddryo/SEO-SIMPLE-PACK.git"
	},
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@wordpress/browserslist-config": "^6.42.0",
		"@wordpress/stylelint-config": "^23.34.0",
		"autoprefixer": "^10.4.27",
		"cssnano": "^7.1.4",
		"glob": "^13.0.6",
		"postcss": "^8.5.8",
		"postcss-sort-media-queries": "^6.3.3",
		"prettier": "^3.8.1",
		"sass": "^1.98.0",
		"stylelint": "^16.18.0",
		"webpack": "^5.105.0",
		"webpack-cli": "^5.1.4"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config",
		"not ie <= 11"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher"
		]
	}
}
